{
  "name": "event-vendor-booking-platform",
  "version": "1.0.0",
  "description": "Event Vendor Booking Platform with AI integrations and advanced features",
  "private": true,
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
