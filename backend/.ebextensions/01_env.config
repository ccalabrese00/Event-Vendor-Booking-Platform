option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    PORT: 8080
    NPM_CONFIG_PRODUCTION: false

  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /api/health: /api/health

container_commands:
  01_build:
    command: "cd /var/app/current && npm install && npm run build"
    leader_only: true
