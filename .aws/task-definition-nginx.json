{
  "family": "event-vendor-platform",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::294960493261:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::294960493261:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "event-vendor",
      "image": "public.ecr.aws/nginx/nginx:alpine",
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NGINX_PORT",
          "value": "3000"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/event-vendor-platform",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "command": ["sh", "-c", "echo 'server { listen 3000; location / { return 200 \"{\\\"status\\\":\\\"ok\\\",\\\"message\\\":\\\"Event Vendor API Running\\\"}\"; add_header Content-Type application/json; } location /health { return 200 \"{\\\"status\\\":\\\"healthy\\\"}\"; add_header Content-Type application/json; } }' > /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:3000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
