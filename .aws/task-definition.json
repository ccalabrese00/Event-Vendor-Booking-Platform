{
  "family": "event-vendor-platform",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::294960493261:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::294960493261:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "event-vendor",
      "image": "294960493261.dkr.ecr.us-east-1.amazonaws.com/event-vendor-platform:latest",
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3001"
        },
        {
          "name": "DATABASE_URL",
          "value": "postgresql://postgres:postgres@event-vendor-db.csryyqoskrql.us-east-1.rds.amazonaws.com:5432/event_vendor_booking?schema=public"
        },
        {
          "name": "NEXTAUTH_SECRET",
          "value": "super-secret-nextauth-key-for-production-deployment"
        },
        {
          "name": "NEXTAUTH_URL",
          "value": "http://event-vendor-alb-462640695.us-east-1.elb.amazonaws.com"
        },
        {
          "name": "JWT_SECRET",
          "value": "super-secret-jwt-key-for-production-deployment"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/event-vendor-platform",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3001/api/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
