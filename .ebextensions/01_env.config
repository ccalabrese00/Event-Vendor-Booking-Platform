option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    PORT: 8080
    DATABASE_URL: '{{resolve:secretsmanager:event-vendor-db:SecretString:DATABASE_URL}}'
    JWT_SECRET: '{{resolve:secretsmanager:event-vendor-secrets:SecretString:JWT_SECRET}}'
    SENDGRID_API_KEY: '{{resolve:secretsmanager:event-vendor-secrets:SecretString:SENDGRID_API_KEY}}'
    FROM_EMAIL: noreply@eventvendor.com
    
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /health: /health
    
  aws:elasticbeanstalk:environment:process:default:
    PORT: 8080
    
  aws:elasticbeanstalk:healthcheck:
    HealthCheckPath: /api/health
